# =============================================================================
# JARVIS V2 — Local Development Defaults
# =============================================================================
# Safe-to-commit baseline for `make dev`. NO real secrets.
# Override per-developer in .env (gitignored).
#
# Usage:
#   cp backend/.env.dev backend/.env
#   (then edit backend/.env to add your real API keys)
# =============================================================================

ENV=development

# ── Required secrets — STUBS ONLY, override in .env for anything sensitive ───
JWT_SECRET=local-dev-jwt-secret-min-32-chars-ok!!
SESSION_SECRET=local-dev-session-secret-32-chars-ok
TOKEN_ENCRYPTION_KEY=bG9jYWwtZGV2LWVuY3J5cHRpb24ta2V5LTMyYg==

# ── Database + Redis (docker-compose service names) ──────────────────────────
DATABASE_URL=postgresql://jarvis:jarvis-dev-pw@postgres:5432/jarvis
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=jarvis-dev-pw

# ── CORS — allow local + Vite dev server ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
FRONTEND_URL=http://localhost

# ── AI defaults ──────────────────────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY blank here; override in .env or via Settings BYOAK.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-5
AI_COMPRESSION_MODEL=claude-haiku-4-5

# ── OAuth redirect URIs — local backend ──────────────────────────────────────
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
MS_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback
MS_TENANT_ID=common
SLACK_REDIRECT_URI=http://localhost:8000/api/auth/slack/callback
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/auth/shopify/callback

# ── Mock OAuth — flips real providers off, useful for offline E2E tests ──────
# When true, /api/auth/{provider}/callback skips real token exchange and
# stores a fake access_token. NOT YET WIRED IN auth.py (Step 23.3 deferred).
MOCK_OAUTH=false

# Storage left empty — uploads return 402 until you add real S3/R2 creds
S3_REGION=auto
