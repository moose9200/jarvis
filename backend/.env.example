# =============================================================================
# JARVIS V2 — Backend Environment Template
# =============================================================================
# Copy to .env (gitignored) and fill in real values.
# Production deploys: set these in your hosting dashboard (Railway/Render),
# never commit .env to git.
#
# Generate secrets:
#   openssl rand -base64 32                                  # JWT_SECRET, SESSION_SECRET
#   python -c "from cryptography.fernet import Fernet; \
#              print(Fernet.generate_key().decode())"        # TOKEN_ENCRYPTION_KEY
# =============================================================================


# ── REQUIRED — app crashes on boot if any are missing ────────────────────────
# Each must be ≥ 32 chars. TOKEN_ENCRYPTION_KEY must be a 44-char Fernet key.
JWT_SECRET=
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=


# ── Database + Redis (managed by docker-compose in dev) ──────────────────────
# In dev, leave both as the docker service URLs.
# In prod, point at your managed Postgres + Redis instances.
DATABASE_URL=postgresql://jarvis:jarvis-dev-pw@postgres:5432/jarvis
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=jarvis-dev-pw


# ── CORS + frontend URL ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed by CORS. Default is local dev.
# Production: set to your domain, e.g. ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
FRONTEND_URL=http://localhost


# ── AI providers (platform-level fallback; users can BYOAK via Settings) ─────
# ANTHROPIC_API_KEY is the default. Without one + no user BYOAK, chat returns 402.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-5
AI_COMPRESSION_MODEL=claude-haiku-4-5

# Optional platform fallbacks. Users can also set their own per-provider keys.
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=


# ── Voice (optional) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=


# ── OAuth — Google (Gmail + Calendar) ────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
# Add redirect URI to your OAuth client first.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback


# ── OAuth — Microsoft (Outlook + Teams) ──────────────────────────────────────
# Get from https://portal.azure.com → App registrations
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback


# ── OAuth — Slack ────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/auth/slack/callback


# ── OAuth — GitHub ───────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback


# ── Issue trackers ───────────────────────────────────────────────────────────
LINEAR_API_KEY=

JIRA_BASE=
JIRA_EMAIL=
JIRA_TOKEN=

NOTION_TOKEN=


# ── Messaging ────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=


# ── E-commerce + support (Step 9, 10 — not wired yet) ────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/auth/shopify/callback

FRESHDESK_SUBDOMAIN=
FRESHDESK_API_KEY=


# ── Object storage (Cloudflare R2 recommended — free 10 GB) ──────────────────
# Without these, file uploads return 402. See USER_TASKS.txt #9.
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_PUBLIC_URL=


# ── Billing (Step 22 — not wired yet) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_FOUNDER_MONTHLY=
STRIPE_PRICE_FOUNDER_ANNUAL=


# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── Observability ───────────────────────────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
GIT_SHA=
